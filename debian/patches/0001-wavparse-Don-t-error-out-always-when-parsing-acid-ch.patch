Fixes https://gitlab.freedesktop.org/gstreamer/gstreamer/-/issues/4495

Part-of: <https://gitlab.freedesktop.org/gstreamer/gstreamer/-/merge_requests/9383>
---
 gst/wavparse/gstwavparse.c | 1 -
 1 file changed, 1 deletion(-)

diff --git a/gst/wavparse/gstwavparse.c b/gst/wavparse/gstwavparse.c
index 90024b3..5adccff 100644
--- a/gst/wavparse/gstwavparse.c
+++ b/gst/wavparse/gstwavparse.c
@@ -1481,7 +1481,6 @@ gst_wavparse_stream_headers (GstWavParse * wav)
           buf = NULL;
           res =
               gst_wavparse_pull_range_exact (wav, wav->offset + 8, size, &buf);
